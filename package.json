{
  "name": "@unscreen/video-background-remover",
  "version": "0.1.8",
  "description": "TypeScript SDK for the Unscreen API - Video Background Removal library",
  "homepage": "https://www.unscreen.io/en/api#api-documentation",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Unscreen-Video-Background-Remover/unscreen-video-background-remover.git"
  },
  "bugs": {
    "url": "https://github.com/Unscreen-Video-Background-Remover/unscreen-video-background-remover/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "npm run build:test && node --test dist-test/test/*.test.js",
    "build:test": "tsc -p tsconfig.test.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit"
  },
  "keywords": [
    "unscreen",
    "background-removal",
    "video background remover",
    "canva alternative",
    "video",
    "sdk",
    "typescript"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  }
}
