{
  "name": "@unscreen/video-background-remover",
  "version": "0.1.1",
  "description": "TypeScript SDK for the Unscreen.io API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "npm run build:test && node --test dist-test/test/*.test.js",
    "build:test": "tsc -p tsconfig.test.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit"
  },
  "keywords": [
    "unscreen",
    "background-removal",
    "video background remover",
    "canva alternative",
    "video",
    "sdk",
    "typescript"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  }
}
